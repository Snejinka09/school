@page "/Teacher"
@inherits TeacherPageViewModel
@using school.web.Components.Pages.Teacher
@rendermode InteractiveServer
<h3>Учителя</h3>


<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Фамилия</th>
            <th>Имя</th>
            <th>Отчество</th>
            <th>Возраст</th>
            <th>Предмет</th>
            <th></th> 
        </tr>
    </thead>
    <tbody>
        @foreach (var teacher in Teachers)
        {
            <tr>
                <td>@teacher.Id</td>
                <td>@teacher.LastName</td>
                <td>@teacher.FirstName</td>
                <td>@teacher.MiddleName</td>
                <td>@teacher.Age</td>
                <td>@teacher.SubjectName</td>
                <td><i class="btn btn-success bi bi-pencil" @onclick="@(() => SelectTeacher(teacher))"></i>
                </td>
            </tr>
        }
    </tbody>
</table>
@if (SelectedTeacher != null)
{
    <input @bind="SelectedTeacher.FirstName" />
    <input @bind="SelectedTeacher.LastName" />
    <input @bind="SelectedTeacher.MiddleName" />
    <input @bind="SelectedTeacher.Age" />
    <input @bind="SelectedTeacher.SubjectName" />
    <button @onclick="Save">Сохранить</button>
}
