@page "/Student"
@inherits StudentPageViewModel
@using school.web.Pages.Student
@rendermode InteractiveServer
<h3>Ученики</h3>


<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Фамилия</th>
            <th>Имя</th>
            <th>Отчество</th>
            <th>Возраст</th>
            <th>Класс</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Students)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.LastName</td>
                <td>@student.FirstName</td>
                <td>@student.MiddleName</td>
                <td>@student.Age</td>
                <td>@student.ClassId</td>
                <td><i class="btn btn-success bi bi-pencil" @onclick="@(() => SelectStudent(student))"></i>
                </td>
            </tr>
        }
    </tbody>
</table>
@if (SelectedStudent != null)
{
    <input @bind="SelectedStudent.FirstName"/>
    <input @bind="SelectedStudent.LastName" />
    <input @bind="SelectedStudent.MiddleName" />
    <input @bind="SelectedStudent.Age" />
    <input @bind="SelectedStudent.ClassId" />
    <button @onclick="Save">Сохранить</button>
}
@code {

}
